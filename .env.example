# Copy to `.env` and fill in. `.env` is gitignored.

# Backend selector: "ollama" (default) or "openai".
# "openai" points at an OpenAI-compatible server (llama.cpp llama-server) —
# e.g. the Kaggle 2xT4 backend serving Gemma 4 12B + EmbeddingGemma via ngrok.
LLM_BACKEND=ollama

# Ollama (Gemma 4 E2B served from Colab via ngrok).
# The ngrok URL CHANGES on every Colab session restart — re-paste each time.
OLLAMA_BASE_URL=https://your-ngrok-url.ngrok-free.app
OLLAMA_BASE_URL_LOCAL=http://172.28.112.1:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_EMBED_MODEL=embeddinggemma:300m
OLLAMA_NUM_CTX=32768

# OpenAI-compatible backend (used only when LLM_BACKEND=openai). Base URL must
# end in /v1; chat and embeddings share it (one ngrok URL behind an nginx proxy
# that routes /v1/embeddings to the embedding server). api_key is a placeholder.
OPENAI_BASE_URL=https://your-stable-ngrok-url.ngrok-free.app/v1
OPENAI_API_KEY=EMPTY
OPENAI_MODEL=gemma4-12b
OPENAI_EMBED_MODEL=emb-gemma

# LangSmith tracing (auto-traces every LangChain LLM call when enabled).
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=answer-dev